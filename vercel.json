{
  "version": 2,
  "name": "tanvir-islam-portfolio",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/dashboard",
      "destination": "/dashboard/index.html"
    },
    {
      "source": "/dashboard/login",
      "destination": "/dashboard/login.html"
    }
  ],
  "headers": [
    {
      "source": "/dashboard/(.*).css",
      "headers": [
        { "key": "Content-Type", "value": "text/css" }
      ]
    }
  ]
}
