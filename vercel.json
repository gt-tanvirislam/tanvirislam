{
  "version": 2,
  "name": "tanvir-islam-portfolio",
  "outputDirectory": ".",
  "routes": [
    {
      "src": "/dashboard",
      "dest": "/dashboard/index.html"
    },
    {
      "src": "/dashboard/login",
      "dest": "/dashboard/login.html"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
